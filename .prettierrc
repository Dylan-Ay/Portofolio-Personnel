{
   "arrowParens": "always",
   "printWidth": 80,
   "singleQuote": true,
   "semi": false,
   "tabWidth": 3,
   "trailingComma": "es5",
   "plugins": ["@prettier/plugin-php"],
   "overrides": [
      {
         "files": "*.php",
         "options": {
            "parser": "php"
         }
      }
   ]
}
